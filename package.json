{
    "name": "react-base-app",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "generate:type": "graphql-codegen --require dotenv/config --config codegen.ts",
        "start": "vite",
        "prebuild": "pnpm generate:type",
        "build": "vite build",
        "pretypecheck": "pnpm generate:type",
        "typecheck": "tsc",
        "prelint:unused": "pnpm generate:type",
        "lint:unused": "knip --no-gitignore --tags=-knipignore",
        "prelint:js": "pnpm generate:type",
        "lint:js": "eslint src",
        "lint:css": "stylelint \"./src/**/*.css\"",
        "lint": "pnpm lint:js && pnpm lint:css",
        "lint:fix": "pnpm lint:js --fix && pnpm lint:css --fix",
        "test": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "engines": {
        "node": "22",
        "pnpm": "10.4.0"
    },
    "dependencies": {
        "@apollo/client": "^3.11.8",
        "@graphql-typed-document-node/core": "^3.2.0",
        "@julr/vite-plugin-validate-env": "^1.1.1",
        "@toast-ui/editor": "^3.2.2",
        "@toast-ui/editor-plugin-code-syntax-highlight": "^3.1.0",
        "@toast-ui/editor-plugin-color-syntax": "^3.1.0",
        "@toast-ui/react-editor": "^3.2.3",
        "@togglecorp/fujs": "^2.0.0",
        "@togglecorp/toggle-form": "^2.0.4",
        "@togglecorp/toggle-ui": "^0.18.3",
        "@types/apollo-upload-client": "^18.0.0",
        "apollo-upload-client": "^18.0.1",
        "graphql": "^16.9.0",
        "prismjs": "^1.30.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-icons": "^5.3.0",
        "react-router-dom": "^6.11.1"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "^5.0.2",
        "@graphql-codegen/client-preset": "^4.3.3",
        "@types/node": "^20.1.3",
        "@types/react": "^18.0.28",
        "@types/react-dom": "^18.0.11",
        "@typescript-eslint/eslint-plugin": "^7.1.1",
        "@typescript-eslint/parser": "^7.1.1",
        "@vitejs/plugin-react-swc": "^3.0.0",
        "@vitest/coverage-v8": "^2.1.3",
        "autoprefixer": "^10.4.14",
        "dotenv": "^16.4.5",
        "eslint": "^8.40.0",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-import-resolver-typescript": "^3.5.5",
        "eslint-plugin-import": "^2.27.5",
        "eslint-plugin-import-newlines": "^1.4.0",
        "eslint-plugin-jsx-a11y": "^6.7.1",
        "eslint-plugin-react": "^7.32.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "happy-dom": "^13.6.2",
        "knip": "^5.33.3",
        "postcss": "^8.3.0",
        "postcss-nested": "^6.0.1",
        "postcss-normalize": "^10.0.1",
        "postcss-preset-env": "^9.4.0",
        "stylelint": "^16.2.1",
        "stylelint-config-concentric": "^2.0.2",
        "stylelint-config-recommended": "^14.0.0",
        "stylelint-no-unused-selectors": "^1.0.40",
        "stylelint-value-no-unknown-custom-properties": "^6.0.1",
        "typescript": "^5.0.4",
        "vite": "^5.1.5",
        "vite-plugin-checker": "^0.6.0",
        "vite-plugin-compression2": "^1.0.0",
        "vite-plugin-svgr": "^4.2.0",
        "vite-plugin-webfont-dl": "^3.7.4",
        "vite-tsconfig-paths": "^4.2.0",
        "vitest": "^1.3.1"
    },
    "packageManager": "pnpm@10.4.0"
}
